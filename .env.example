# Cypher environment configuration. Copy to .env and fill in.

# Flask session signing key (use a long random string in production)
SECRET_KEY=change-me

# Postgres connection string (Render Postgres, or a local Postgres for dev)
DATABASE_URL=postgresql://user:password@host:5432/cypher

# Notification channels are toggled in the Settings UI (stored in the DB).
# These only seed the initial settings on first run.
# Default: Telegram disabled, Discord enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Seeded on first run if no admin exists; change in-app afterwards
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=cypher-admin

# Timezone all schedules align to (IST)
APP_TIMEZONE=Asia/Kolkata

# Set to 0 to disable the in-process scheduler (e.g. when running migrations only)
SCHEDULER_ENABLED=1
